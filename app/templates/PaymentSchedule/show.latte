{block content}
<h1>
  <a href="{link Uzivatel:show id=>$u->id}">UID {$u->id} - {$u->jmeno} {$u->prijmeni} ({$u->nick})</a>
  - rozpis plateb
</h1>

<a n:href="PaymentSchedule:sendPaymentScheduleEmail id=>$u->id" role="button" class="btn btn-primary btn-sm" id="btn-handle-sendPaymentScheduleEmail">
    <b>@</b> Odeslat rozpis plateb e-mailem na adresu {$u->email}
</a>
<br/>
<br/>

<div id="rozpis-preview">
{include 'paymentSchedule.latte'}
</div>

<script>
  $('#btn-handle-sendPaymentScheduleEmail').on('click', function() {
      const c = confirm("Rozpis plateb bude odeslán na e-mail "+{$u->email}+".\n\nPokračovat?");
      if (c) {
          // Ok
      } else {
          // Cancel
          event.preventDefault();
      }
  })
</script>

<style>
  div#rozpis-preview {
    padding: 1em;
    border: 1px solid gray;
  }
</style>

{/block}
